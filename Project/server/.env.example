# ============================================================
# ShopEZ Server — Environment Variables
# ============================================================
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit the .env file — it's in .gitignore
# ============================================================

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopez?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret — use any long random string (min. 32 characters)
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars

# Token expiry (30d = 30 days)
JWT_EXPIRE=30d
